{
  "name": "@yomiru/backend",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./scraper": "./src/scraper/strategies/registry.ts",
    "./scraper/*": "./src/scraper/*.ts",
    "./scraper/strategies/*": "./src/scraper/strategies/*.ts"
  },
  "scripts": {
    "dev": "npm run build && node dist/apps/backend/src/index.js",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc",
    "test": "tsx --test src/scraper/strategies/*.test.ts",
    "test:watch": "tsx --test --watch src/scraper/strategies/*.test.ts",
    "prestart": "npm run build",
    "start": "node dist/apps/backend/src/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/rate-limit": "^10.0.0",
    "@sinclair/typebox": "^0.34.0",
    "@supabase/supabase-js": "^2.49.0",
    "@yomiru/shared": "*",
    "cheerio": "^1.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.0",
    "playwright": "^1.50.0",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "rebrowser-playwright": "^1.52.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "pg": "^8.18.0",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.4.0"
  }
}
