<div
  id="yomiru-growth-promo"
  class="fixed inset-0 z-[95] hidden overflow-y-auto bg-black/80 px-4 py-4 backdrop-blur-sm sm:items-center sm:justify-center sm:py-6"
  role="dialog"
  aria-modal="true"
  aria-labelledby="yomiru-growth-promo-title"
>
  <div class="relative my-auto w-full max-w-4xl overflow-hidden rounded-[28px] border border-white/10 bg-zinc-950 shadow-2xl shadow-black/80">
    <button
      id="yomiru-growth-promo-close"
      type="button"
      class="absolute right-4 top-4 z-10 inline-flex h-11 w-11 items-center justify-center rounded-full border border-white/10 bg-black/40 text-zinc-300 transition hover:border-accent/50 hover:text-white"
      aria-label="Cerrar anuncio"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.2" d="M6 6l12 12M18 6L6 18" />
      </svg>
    </button>

    <div class="grid md:min-h-0 md:grid-cols-[1.05fr_0.95fr]">
      <div class="relative overflow-hidden bg-[radial-gradient(circle_at_top_left,_rgba(249,115,22,0.35),_transparent_42%),linear-gradient(135deg,_#18181b_0%,_#0a0a0d_50%,_#111114_100%)] p-5 sm:p-8 md:p-10">
        <div class="absolute inset-0 opacity-70">
          <div class="absolute left-[-12%] top-[-10%] h-40 w-40 rounded-full bg-accent/25 blur-3xl"></div>
          <div class="absolute bottom-[-10%] right-[-8%] h-44 w-44 rounded-full bg-red-500/15 blur-3xl"></div>
          <div class="absolute left-8 top-8 h-24 w-24 rotate-12 rounded-3xl border border-white/10 bg-white/5"></div>
          <div class="absolute bottom-10 left-12 h-16 w-28 -rotate-12 rounded-full border border-white/10 bg-white/5"></div>
        </div>

        <div class="relative flex h-full flex-col justify-between gap-6 sm:gap-8">
          <div class="space-y-3 sm:space-y-4">
            <span class="inline-flex rounded-full border border-accent/30 bg-accent/15 px-4 py-2 text-[10px] font-black uppercase tracking-[0.28em] text-accent">
              Comunidad Yomiru
            </span>

            <div class="space-y-2 sm:space-y-3">
              <p class="max-w-xs text-balance text-2xl font-black italic uppercase leading-none tracking-tight text-white sm:text-4xl md:text-5xl">
                Ayudanos a seguir creciendo la libreria
              </p>
              <p class="max-w-md text-sm leading-6 text-zinc-300 sm:text-base sm:leading-7">
                Si deseas un manga nuevo o realizas scans, queremos escucharte. Cada aporte nos ayuda a
                ampliar el catalogo y mejorar la biblioteca para todos.
              </p>
            </div>
          </div>

          <div class="relative rounded-[24px] border border-white/10 bg-black/30 p-4 shadow-xl shadow-black/30 sm:p-5">
            <div class="mb-4 flex items-center gap-3">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-2xl bg-accent text-xl font-black text-zinc-950 shadow-lg shadow-accent/30 sm:h-12 sm:w-12 sm:text-2xl">
                読
              </div>
              <div class="min-w-0">
                <p class="text-[10px] font-black uppercase tracking-[0.24em] text-accent">Impulsa el proyecto</p>
                <p class="text-xl font-bold leading-tight text-white sm:text-sm">
                  Nuevos mangas, scans y reportes
                </p>
              </div>
            </div>

            <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
              <div class="min-w-0 rounded-2xl border border-white/10 bg-white/5 p-3">
                <p class="text-[9px] font-black uppercase tracking-[0.14em] text-zinc-400 sm:text-[10px] sm:tracking-[0.16em]">
                  Solicitudes
                </p>
                <p class="mt-2 text-base font-black text-white sm:text-lg">Mangas</p>
              </div>
              <div class="min-w-0 rounded-2xl border border-white/10 bg-white/5 p-3">
                <p class="text-[9px] font-black uppercase tracking-[0.14em] text-zinc-400 sm:text-[10px] sm:tracking-[0.16em]">
                  Colabora
                </p>
                <p class="mt-2 text-base font-black text-white sm:text-lg">Scans</p>
              </div>
              <div class="min-w-0 rounded-2xl border border-white/10 bg-white/5 p-3">
                <p class="text-[9px] font-black uppercase tracking-[0.14em] text-zinc-400 sm:text-[10px] sm:tracking-[0.16em]">
                  Soporte
                </p>
                <p class="mt-2 text-base font-black text-white sm:text-lg">Contacto</p>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="flex flex-col justify-center bg-zinc-950 p-5 sm:p-8 md:p-10">
        <div class="space-y-6">
          <div>
            <p class="text-[10px] font-black uppercase tracking-[0.28em] text-accent">Haz crecer Yomiru</p>
            <h2 id="yomiru-growth-promo-title" class="mt-3 text-[2rem] font-black uppercase leading-none tracking-tight text-white sm:text-4xl">
              Contactanos aqui
            </h2>
            <p class="mt-4 text-sm leading-6 text-zinc-400 sm:text-base sm:leading-7">
              Escríbenos si quieres pedir una serie, reportar una fuente o sumarte con scans. El mensaje
              llega directo al equipo para revisarlo cuanto antes.
            </p>
          </div>

          <div class="space-y-3 rounded-[24px] border border-white/10 bg-white/[0.03] p-5">
            <div class="flex items-start gap-3">
              <span class="mt-1 flex h-7 w-7 items-center justify-center rounded-full bg-accent/15 text-xs font-black text-accent">1</span>
              <p class="text-sm leading-6 text-zinc-300">Pide un manga que aún no esté en la biblioteca.</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="mt-1 flex h-7 w-7 items-center justify-center rounded-full bg-accent/15 text-xs font-black text-accent">2</span>
              <p class="text-sm leading-6 text-zinc-300">Comparte una fuente o dinos si haces scans.</p>
            </div>
            <div class="flex items-start gap-3">
              <span class="mt-1 flex h-7 w-7 items-center justify-center rounded-full bg-accent/15 text-xs font-black text-accent">3</span>
              <p class="text-sm leading-6 text-zinc-300">Coordina con nosotros desde la página de contacto.</p>
            </div>
          </div>

          <div class="flex flex-col gap-3 sm:flex-row">
            <a
              href="/contacto"
              class="inline-flex min-h-12 items-center justify-center rounded-full bg-accent px-6 text-[11px] font-black uppercase tracking-[0.22em] text-zinc-950 transition hover:bg-white"
            >
              Quiero contactarlos
            </a>
            <button
              id="yomiru-growth-promo-later"
              type="button"
              class="inline-flex min-h-12 items-center justify-center rounded-full border border-white/10 px-6 text-[11px] font-black uppercase tracking-[0.22em] text-zinc-300 transition hover:border-white/30 hover:text-white"
            >
              Tal vez luego
            </button>
          </div>

          <p class="text-xs leading-6 text-zinc-500">
            Este aviso se muestra una vez por sesion para no interrumpir en cada pagina.
          </p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    (function () {
      const KEY = 'yomiru:growth-promo:v1';
      const root = document.getElementById('yomiru-growth-promo');
      const close = document.getElementById('yomiru-growth-promo-close');
      const later = document.getElementById('yomiru-growth-promo-later');
      if (!root || !close || !later) return;

      function rememberDismissal() {
        try {
          sessionStorage.setItem(KEY, '1');
        } catch {}
      }

      function hide() {
        root.classList.add('hidden');
        root.classList.remove('flex');
        document.body.classList.remove('overflow-hidden');
      }

      function show() {
        root.classList.remove('hidden');
        root.classList.add('flex');
        document.body.classList.add('overflow-hidden');
      }

      function maybeShow() {
        try {
          if (sessionStorage.getItem(KEY) === '1') return;
        } catch {}
        window.setTimeout(show, 240);
      }

      const dismiss = () => {
        rememberDismissal();
        hide();
      };

      close.addEventListener('click', dismiss);
      later.addEventListener('click', dismiss);
      root.addEventListener('click', (event) => {
        if (event.target === root) dismiss();
      });
      window.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && !root.classList.contains('hidden')) dismiss();
      });
      window.addEventListener('pageshow', maybeShow);
      maybeShow();
    })();
  </script>
</div>
