---
import { readShowAdult } from '../lib/nsfw';
import { getUser } from '../lib/supabase';
import GrowthPromoModal from '../components/GrowthPromoModal.astro';
import StickyMobileAd from '../components/StickyMobileAd.astro';

export interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Yomiru — Lector de manga' } = Astro.props;
const showAdult = readShowAdult(Astro.cookies);
const currentPath = Astro.url.pathname + Astro.url.search;
const hideStickyAd =
  /^\/manga\/[^/]+\/[^/]+$/.test(Astro.url.pathname) ||
  ['/login', '/registro', '/recuperar', '/restablecer'].includes(Astro.url.pathname);
const hideGrowthPromo =
  /^\/manga\/[^/]+\/[^/]+$/.test(Astro.url.pathname) ||
  ['/login', '/registro', '/recuperar', '/restablecer', '/contacto'].includes(Astro.url.pathname);
const quickGenreLinks = [
  ['Shounen', 'Shounen'],
  ['Seinen', 'Seinen'],
  ['Shoujo', 'Shoujo'],
  ['BL', 'Boys Love'],
];

let currentUser: { email: string | null } | null = null;
try {
  const { user } = await getUser(Astro.request, Astro.cookies);
  if (user) currentUser = { email: user.email ?? null };
} catch {
  // supabase env vars missing in some envs — ignore
}
---

<!DOCTYPE html>
<html lang="es" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Noto+Sans+JP:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <title>{title} — Yomiru</title>
    <style is:global>
      :root { color-scheme: dark; }
      html, body { background: #000; color: #fff; }
      body { font-family: 'Inter', 'Noto Sans JP', system-ui, sans-serif; }

      ::selection { background: rgba(233, 80, 0, 0.35); color: #ff9b61; }

      ::-webkit-scrollbar { width: 10px; height: 10px; }
      ::-webkit-scrollbar-track { background: #000; }
      ::-webkit-scrollbar-thumb { background: #27272a; border-radius: 5px; }
      ::-webkit-scrollbar-thumb:hover { background: #E95000; }

      .no-scrollbar::-webkit-scrollbar { display: none; }
      .no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }

      .snap-row {
        scroll-snap-type: x proximity;
        -webkit-overflow-scrolling: touch;
        overscroll-behavior-x: contain;
        touch-action: pan-x;
      }
      .snap-row .snap-item { scroll-snap-align: start; }

      /* Bolt loader */
      .yomiru-bolt-fill { animation: yomiru-bolt-fill 1.3s ease-in-out infinite; }
      @keyframes yomiru-bolt-fill {
        0%   { y: 24; height: 0; opacity: 1; }
        55%  { y: 0;  height: 24; opacity: 1; }
        85%  { y: 0;  height: 24; opacity: 0.95; }
        100% { y: 0;  height: 24; opacity: 0; }
      }
      .yomiru-bolt { filter: drop-shadow(0 0 4px rgba(233, 80, 0, 0.55)); }
      .yomiru-nav-bolt { filter: drop-shadow(0 0 14px rgba(233, 80, 0, 0.7)); }
      #yomiru-nav-loader.flex { display: flex; }

      .inline-submit-loader {
        position: relative;
        overflow: hidden;
      }
      .inline-submit-loader::after {
        content: "";
        position: absolute;
        left: 50%;
        top: 50%;
        width: 18px;
        height: 18px;
        margin: -9px 0 0 -9px;
        border-radius: 999px;
        border: 2px solid currentColor;
        border-right-color: transparent;
        opacity: 0;
        pointer-events: none;
      }
      form.is-submitting .inline-submit-loader {
        pointer-events: none;
      }
      form.is-submitting .inline-submit-loader > span {
        opacity: 0;
      }
      form.is-submitting .inline-submit-loader::after {
        opacity: 1;
        animation: inline-spin 720ms linear infinite;
      }
      @keyframes inline-spin {
        to { transform: rotate(360deg); }
      }

      /* Outline text trick used by hero title */
      .text-outline-white {
        -webkit-text-stroke: 1.5px #fff;
      }
    </style>
  </head>
  <body class="min-h-screen bg-zinc-950 text-zinc-100 font-sans antialiased selection:bg-accent/30 selection:text-accent-300">
    <div
      id="yomiru-nav-loader"
      class="fixed inset-0 z-[100] items-center justify-center pointer-events-none hidden bg-black/70 backdrop-blur-sm"
      aria-hidden="true"
      role="status"
    >
      <img
        src="/shinji-loader.gif"
        alt=""
        width="400"
        height="400"
        class="block rounded-2xl"
      />
    </div>

    <script is:inline>
      (function () {
        const loader = document.getElementById('yomiru-nav-loader');
        if (!loader) return;
        const show = () => { loader.classList.remove('hidden'); loader.classList.add('flex'); };
        const hide = () => { loader.classList.add('hidden'); loader.classList.remove('flex'); };
        document.addEventListener('click', (e) => {
          const a = e.target instanceof Element ? e.target.closest('a[href]') : null;
          if (!a) return;
          if (a.hasAttribute('data-no-loader')) return;
          if (a.target === '_blank' || a.hasAttribute('download')) return;
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey || e.button !== 0) return;
          const href = a.getAttribute('href') || '';
          if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
          try {
            const url = new URL(href, location.href);
            if (url.origin !== location.origin) return;
            if (url.pathname === location.pathname && url.search === location.search) return;
            if (url.pathname === '/login' || url.pathname === '/registro' || url.pathname === '/recuperar') return;
          } catch { return; }
          show();
        });
        document.addEventListener('submit', (e) => {
          const f = e.target;
          if (!(f instanceof HTMLFormElement)) return;
          if (f.method.toLowerCase() !== 'post') return;
          if (f.hasAttribute('data-inline-submit')) {
            f.classList.add('is-submitting');
            const submit = f.querySelector('button[type="submit"]');
            if (submit instanceof HTMLButtonElement) {
              submit.disabled = true;
              submit.setAttribute('aria-busy', 'true');
            }
            return;
          }
          if (f.hasAttribute('data-no-loader')) return;
          show();
        });
        window.addEventListener('pageshow', hide);
        window.addEventListener('pagehide', hide);
      })();
    </script>

    <header class="fixed top-0 left-0 right-0 z-50 bg-zinc-950/95 backdrop-blur-xl border-b border-zinc-800 py-3 shadow-2xl shadow-black/50">
      <nav class="max-w-7xl mx-auto px-4 md:px-8 flex items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 group">
          <div class="w-10 h-10 rounded-xl bg-accent flex items-center justify-center group-hover:scale-110 transition-transform shadow-lg shadow-accent/30">
            <span class="text-zinc-950 text-lg font-black">読</span>
          </div>
          <span class="text-xl font-bold tracking-tight bg-clip-text text-transparent bg-gradient-to-r from-white to-zinc-400">
            Yomiru<span class="text-accent">.</span>
          </span>
        </a>
        <div class="flex items-center gap-3 md:gap-6">
          <div class="hidden lg:flex items-center gap-4">
            {quickGenreLinks.map(([label, genre]) => (
              <a
                href={`/mangas?genre=${encodeURIComponent(genre)}`}
                class="text-sm font-bold text-zinc-400 hover:text-white transition-colors"
              >
                {label}
              </a>
            ))}
          </div>
          <a href="/mangas" class="hidden md:inline text-sm font-bold text-zinc-400 hover:text-white transition-colors">Catálogo</a>
          {currentUser && (
            <a href="/biblioteca" class="hidden md:inline text-sm font-bold text-zinc-400 hover:text-white transition-colors">Biblioteca</a>
          )}
          <div class="hidden md:block h-6 w-px bg-zinc-800"></div>
          <form method="POST" action="/api/nsfw" class="flex items-center" data-no-loader>
            <input type="hidden" name="enabled" value={showAdult ? '0' : '1'} />
            <input type="hidden" name="redirect" value={currentPath} />
            <button
              type="submit"
              aria-pressed={showAdult ? 'true' : 'false'}
              title={showAdult ? 'Ocultar contenido +18' : 'Mostrar contenido +18'}
              class={`min-h-11 min-w-11 md:min-h-9 md:min-w-9 rounded-full flex items-center justify-center font-black text-[10px] tracking-tight transition-all shadow-lg touch-manipulation ${
                showAdult
                  ? 'bg-accent text-zinc-950 shadow-accent/30'
                  : 'bg-white text-zinc-950 shadow-white/5 hover:bg-accent hover:shadow-accent/30'
              }`}
            >
              18+
            </button>
          </form>

          {currentUser ? (
            <form method="POST" action="/api/auth/logout" class="flex items-center">
              <input type="hidden" name="redirect" value={currentPath} />
              <button
                type="submit"
                title={`Cerrar sesión (${currentUser.email})`}
                class="w-9 h-9 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-300 hover:text-accent hover:border-accent/50 transition-colors"
              >
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
              </button>
            </form>
          ) : (
            <a
              href={`/login?redirect=${encodeURIComponent(currentPath)}`}
              data-no-loader
              class="rounded-full bg-white text-zinc-950 px-4 py-2 text-[10px] font-black uppercase tracking-widest hover:bg-accent transition-colors"
            >
              Entrar
            </a>
          )}
        </div>
      </nav>
      <form action="/mangas" method="GET" class="md:hidden max-w-7xl mx-auto px-4 pt-3">
        <label class="relative block">
          <span class="sr-only">Buscar manga</span>
          <svg
            class="absolute left-4 top-1/2 -translate-y-1/2 h-4 w-4 text-zinc-500"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11a6 6 0 11-12 0 6 6 0 0112 0z" />
          </svg>
          <input
            type="search"
            name="q"
            placeholder="Buscar manga..."
            class="w-full rounded-full border border-zinc-800 bg-zinc-900 px-11 py-2.5 text-sm font-medium text-white placeholder-zinc-500 outline-none focus:border-accent/60 focus:ring-2 focus:ring-accent/20"
          />
        </label>
      </form>
    </header>

    <main class="min-h-[70vh] pt-32 md:pt-16">
      <slot />
    </main>

    <div
      id="yomiru-disclaimer"
      class="fixed inset-x-0 bottom-0 z-[90] hidden px-3 pb-3 sm:px-6 sm:pb-6"
      aria-live="polite"
    >
      <div class="mx-auto max-w-4xl rounded-2xl border border-zinc-800 bg-zinc-950/95 backdrop-blur-xl shadow-2xl shadow-black/70 p-4 sm:p-5 flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-5">
        <div class="flex-shrink-0 w-9 h-9 rounded-lg bg-accent/15 border border-accent/30 flex items-center justify-center">
          <span class="text-accent font-black text-lg leading-none">!</span>
        </div>
        <p class="flex-1 text-[11px] sm:text-xs leading-relaxed text-zinc-300">
          <span class="font-black uppercase tracking-widest text-white block sm:inline">Aviso · Disclaimer.</span>
          <span class="block sm:inline sm:ml-1">
            Todo el contenido pertenece a sus autores, traductores y scanlations originales; lo redistribuimos con fines informativos y de preservación. Si eres autor o scan y deseas retirar tu obra, contáctanos.
          </span>
        </p>
        <button
          id="yomiru-disclaimer-accept"
          type="button"
          class="flex-shrink-0 rounded-full bg-accent px-5 py-2 text-[11px] font-black uppercase tracking-widest text-zinc-950 hover:bg-white transition-colors shadow-glow-accent"
        >
          Aceptar
        </button>
      </div>
    </div>

    <script is:inline>
      (function () {
        const KEY = 'yomiru:disclaimer:v1';
        const el = document.getElementById('yomiru-disclaimer');
        const btn = document.getElementById('yomiru-disclaimer-accept');
        if (!el || !btn) return;
        try {
          if (localStorage.getItem(KEY) === '1') return;
        } catch {}
        el.classList.remove('hidden');
        btn.addEventListener('click', () => {
          try { localStorage.setItem(KEY, '1'); } catch {}
          el.classList.add('hidden');
        });
      })();
    </script>

    <footer class="bg-zinc-950 border-t border-zinc-900 pt-12 pb-8 mt-16">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 pb-6">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-accent rounded-lg flex items-center justify-center">
              <span class="text-zinc-950 font-black text-lg">読</span>
            </div>
            <span class="text-lg font-bold tracking-tight text-white">
              Yomiru<span class="text-accent">.</span>
            </span>
          </div>
          <div class="flex gap-6 text-[10px] font-bold text-zinc-600 uppercase tracking-widest">
            <a href="/mangas" class="hover:text-white transition-colors">Catálogo</a>
            <a href="/preguntas-respuestas" class="hover:text-white transition-colors">Preguntas</a>
            <a href="/contacto" class="hover:text-white transition-colors">Contacto</a>
          </div>
        </div>
        <p class="mx-auto max-w-3xl border-t border-zinc-900 pt-6 text-center text-[10px] font-bold uppercase tracking-[0.16em] leading-relaxed text-zinc-600">
          Disclaimer: Todo el contenido pertenece a sus respectivos autores, traductores y scanlations. Redistribución informativa; si eres autor o scan y quieres retirar tu obra, usa la página de contacto.
        </p>
        <div class="pt-5 text-center text-zinc-700 text-[10px] uppercase tracking-widest">
          © 2026 Yomiru
        </div>
      </div>
    </footer>

    {!hideGrowthPromo && <GrowthPromoModal />}
    {!hideStickyAd && <StickyMobileAd />}
  </body>
</html>
