---
import Base from '../../layouts/Base.astro';
import AdminMangaGrid from '../../components/AdminMangaGrid.tsx';
import { getSeriesForAdmin, getCoverUrl, type AdminAdultFilter } from '../../lib/db';
import { isAdmin } from '../../lib/admin';

if (!isAdmin(Astro.cookies)) {
  return Astro.redirect(`/admin?redirect=${encodeURIComponent(Astro.url.pathname)}`);
}

const PER_PAGE = 100;
const url = Astro.url;
const page = Math.max(1, parseInt(url.searchParams.get('page') ?? '1', 10) || 1);
const rawFilter = url.searchParams.get('filter') ?? 'all';
const filter: AdminAdultFilter = rawFilter === 'adult' || rawFilter === 'non-adult' ? rawFilter : 'all';
const search = url.searchParams.get('q')?.trim() ?? '';

const { series, total } = await getSeriesForAdmin(page, PER_PAGE, { filter, search });
const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));

const items = series.map((s) => ({
  id: s.id,
  slug: s.slug,
  title: s.title,
  coverUrl: getCoverUrl(s),
  isAdult: s.isAdult,
}));

function buildUrl(overrides: Record<string, string | number | null>) {
  const params = new URLSearchParams(url.searchParams);
  for (const [k, v] of Object.entries(overrides)) {
    if (v === null || v === '') params.delete(k);
    else params.set(k, String(v));
  }
  const qs = params.toString();
  return qs ? `${url.pathname}?${qs}` : url.pathname;
}

const filterOptions: Array<{ value: AdminAdultFilter; label: string }> = [
  { value: 'all', label: 'Todos' },
  { value: 'adult', label: 'Marcados +18' },
  { value: 'non-adult', label: 'Sin marcar' },
];
---

<Base title="Gestión · Series">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-8">
      <div>
        <div class="flex items-center gap-2 mb-1.5">
          <span class="w-1 h-4 rounded-full bg-accent shadow-glow-accent"></span>
          <span class="text-accent text-[11px] font-bold tracking-[0.18em] uppercase">Gestión</span>
        </div>
        <h1 class="font-display text-3xl tracking-tight text-white">Marcar series +18</h1>
        <p class="text-sm text-zinc-400 mt-1">
          Página {page} de {totalPages} · {total.toLocaleString()} series
        </p>
      </div>
      <a href="/admin" class="text-sm text-zinc-400 hover:text-accent transition-colors">
        ← Panel de gestión
      </a>
    </div>

    <form method="GET" class="flex flex-wrap items-center gap-3 mb-8 p-3 bg-ink-800/60 rounded-2xl border border-white/5 backdrop-blur-sm">
      <div class="flex items-center gap-1">
        {filterOptions.map((opt) => (
          <a
            href={buildUrl({ filter: opt.value === 'all' ? null : opt.value, page: 1 })}
            class={`px-3 py-1.5 rounded-full text-xs font-semibold transition-colors ${
              filter === opt.value
                ? 'bg-accent text-zinc-950 shadow-glow-accent'
                : 'bg-white/5 text-zinc-300 hover:bg-white/10'
            }`}
          >
            {opt.label}
          </a>
        ))}
      </div>

      <div class="flex-1 min-w-[200px]">
        <input
          type="search"
          name="q"
          value={search}
          placeholder="Buscar por título…"
          class="w-full px-4 py-1.5 rounded-full border border-white/10 bg-primary-900/60 text-white text-sm placeholder-zinc-500 focus:outline-none focus:border-accent/60 focus:ring-1 focus:ring-accent/40"
        />
      </div>
      <button
        type="submit"
        class="px-4 py-1.5 rounded-full bg-accent text-zinc-950 text-sm font-bold hover:bg-accent-400 transition-colors shadow-glow-accent"
      >
        Buscar
      </button>
      {search && (
        <a
          href={buildUrl({ q: null, page: 1 })}
          class="text-xs text-zinc-400 hover:text-accent underline underline-offset-4"
        >
          limpiar
        </a>
      )}
    </form>

    {items.length === 0 ? (
      <div class="text-center py-24 text-zinc-500 border border-dashed border-white/10 rounded-2xl bg-ink-800/40">
        <p class="text-lg">Nada que mostrar</p>
      </div>
    ) : (
      <AdminMangaGrid items={items} client:load />
    )}

    {totalPages > 1 && (
      <div class="flex items-center justify-center gap-2 mt-12">
        {page > 1 && (
          <a
            href={buildUrl({ page: page - 1 })}
            class="px-4 py-2 rounded-full border border-white/10 bg-ink-800/70 text-sm text-zinc-300 hover:border-accent/60 hover:text-white transition-colors"
          >
            ← Anterior
          </a>
        )}
        <span class="text-sm text-zinc-400 px-3 tabular-nums">
          {page} / {totalPages}
        </span>
        {page < totalPages && (
          <a
            href={buildUrl({ page: page + 1 })}
            class="px-4 py-2 rounded-full border border-white/10 bg-ink-800/70 text-sm text-zinc-300 hover:border-accent/60 hover:text-white transition-colors"
          >
            Siguiente →
          </a>
        )}
      </div>
    )}
  </div>
</Base>
