---
import Base from '../../layouts/Base.astro';
import AdBanner from '../../components/AdBanner.astro';
import ChapterList from '../../components/ChapterList.tsx';
import SeriesComments from '../../components/SeriesComments.tsx';
import { getSeriesPageBundle, getCoverUrl } from '../../lib/db';
import { formatGenre, formatStatus } from '../../lib/labels';
import { readShowAdult } from '../../lib/nsfw';
import { isAdmin } from '../../lib/admin';
import { getUser } from '../../lib/supabase';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/');

const bundle = await getSeriesPageBundle(slug, true);
if (!bundle) return new Response('Not Found', { status: 404 });
const { series, chapters, genres, backgroundUrl } = bundle;

const showAdult = readShowAdult(Astro.cookies);
const admin = isAdmin(Astro.cookies);
if (series.isAdult && !showAdult && !admin) {
  return Astro.redirect('/');
}
const oldestChapter = chapters[0] ?? null;
const latestChapter = chapters[chapters.length - 1] ?? null;
const coverUrl = getCoverUrl(series);
const enrichStatus = Astro.url.searchParams.get('enrich');
const bannerStatus = Astro.url.searchParams.get('banner');
const commentStatus = Astro.url.searchParams.get('comment');
const ratingStatus = Astro.url.searchParams.get('rating');
const monitorStatus = Astro.url.searchParams.get('monitor');

let isFavorite = false;
let isLoggedIn = false;
let currentUserEmail: string | null = null;
const communityRating = series.rating ?? null;
const communityRatingCount = series.voteCount ?? 0;
try {
  const { user } = await getUser(Astro.request, Astro.cookies);
  if (user) {
    isLoggedIn = true;
    currentUserEmail = user.email ?? null;
  }
} catch {
  // supabase down — treat as logged out
}

let altTitles: string[] = [];
try {
  if (Array.isArray(series.altTitles)) altTitles = series.altTitles;
} catch {}

const seriesStatusColor: Record<string, string> = {
  ongoing: 'bg-emerald-500/15 text-emerald-300 border-emerald-500/30',
  completed: 'bg-accent/15 text-accent-300 border-accent/30',
  hiatus: 'bg-amber-500/15 text-amber-300 border-amber-500/30',
  cancelled: 'bg-accent-900/40 text-accent-300 border-accent/30',
};

const statusLabel = formatStatus(series.status);
const statusKey = series.status?.toLowerCase() ?? '';
---

<Base title={series.title} description={series.description ?? undefined}>
  <div class="relative md:-mt-16">
    <div class="absolute inset-x-0 top-0 h-[620px] overflow-hidden">
      <img
        src={backgroundUrl ?? coverUrl}
        alt=""
        aria-hidden="true"
        class="h-full w-full object-cover object-center opacity-50 blur-[1px] scale-105"
        onerror="this.src='/placeholder-cover.svg'"
      />
      <div class="absolute inset-0 bg-gradient-to-b from-zinc-950/15 via-zinc-950/72 to-zinc-950" />
      <div class="absolute inset-0 bg-gradient-to-r from-zinc-950 via-zinc-950/55 to-zinc-950/15" />
    </div>

    <section class="relative max-w-[1440px] mx-auto px-4 md:px-8 pt-8 md:pt-28 pb-20">
      <div class="grid lg:grid-cols-[320px_1fr] gap-8 lg:gap-12 items-start">
        <aside class="space-y-6">
          <div class="w-56 sm:w-64 lg:w-full max-w-[320px] mx-auto lg:mx-0 rounded-2xl overflow-hidden border border-white/10 bg-zinc-900 shadow-2xl shadow-black/70">
            <img
              src={coverUrl}
              alt={series.title}
              class="w-full aspect-[2/3] object-cover"
              onerror="this.src='/placeholder-cover.svg'"
            />
          </div>

          {isLoggedIn ? (
            <form method="POST" action={`/api/favorites/${slug}`} class="w-full max-w-[320px] mx-auto lg:mx-0" data-inline-submit data-no-loader>
              <input type="hidden" name="redirect" value={`/manga/${slug}`} />
              <input type="hidden" name="action" value="toggle" />
              <button
                type="submit"
                class="inline-submit-loader w-full flex items-center justify-center gap-2 rounded-xl bg-accent px-5 py-4 text-xs font-black uppercase tracking-[0.18em] text-zinc-950 shadow-glow-accent transition-colors hover:bg-white"
              >
                <span>{isFavorite ? '★ En tu biblioteca' : '☆ Guardar en biblioteca'}</span>
              </button>
            </form>
          ) : (
            <div class="w-full max-w-[320px] mx-auto lg:mx-0 space-y-2">
              <a
                href={`/login?redirect=${encodeURIComponent(`/manga/${slug}`)}`}
                data-no-loader
                class="flex items-center justify-center gap-2 rounded-xl bg-accent px-5 py-4 text-xs font-black uppercase tracking-[0.18em] text-zinc-950 shadow-glow-accent hover:bg-white transition-colors"
              >
                ☆ Añadir a favoritos
              </a>
              <p class="text-[10px] text-zinc-600 text-center">
                Necesitas una cuenta para guardar tu biblioteca.
              </p>
            </div>
          )}

          <div class="max-w-[320px] mx-auto lg:mx-0 grid grid-cols-2 gap-3">
            {statusLabel && (
              <div>
                <p class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-600 mb-1">Estado</p>
                <span class={`inline-flex rounded-lg border px-3 py-2 text-xs font-black uppercase tracking-widest ${seriesStatusColor[statusKey] ?? 'bg-white/5 text-zinc-300 border-white/10'}`}>
                  {statusLabel}
                </span>
              </div>
            )}
            {series.year && (
              <div>
                <p class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-600 mb-1">Año</p>
                <p class="text-white font-black">{series.year}</p>
              </div>
            )}
            {series.rating != null && (
              <div>
                <p class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-600 mb-1">Puntaje</p>
                <p class="text-white font-black"><span class="text-accent">★</span> {series.rating.toFixed(1)}</p>
              </div>
            )}
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-600 mb-1">Lectores</p>
              <p class="text-white font-black">
                {communityRating != null ? communityRating.toFixed(1) : '—'}
                <span class="text-zinc-500 text-sm font-bold"> / 5</span>
              </p>
            </div>
            <div>
              <p class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-600 mb-1">Disponibles</p>
              <p class="text-white font-black">
                {chapters.length}
                {latestChapter && latestChapter.number > chapters.length && (
                  <span class="text-zinc-500 text-sm font-bold"> / {latestChapter.number}</span>
                )}
              </p>
            </div>
          </div>

          <div class="max-w-[320px] mx-auto lg:mx-0 rounded-2xl border border-zinc-800 bg-zinc-950/70 p-4">
            <div class="flex items-center justify-between gap-3">
              <div>
                <p class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-600">Tu rating</p>
                <p class="text-xs text-zinc-500">{communityRatingCount} {communityRatingCount === 1 ? 'voto' : 'votos'}</p>
              </div>
            </div>
            {isLoggedIn ? (
              <form method="POST" action={`/api/series/${slug}/rating`} class="mt-3 flex gap-1" data-inline-submit data-no-loader>
                <input type="hidden" name="redirect" value={`/manga/${slug}`} />
                {[1, 2, 3, 4, 5].map((value) => (
                  <button
                    type="submit"
                    name="rating"
                    value={value}
                    aria-label={`Votar ${value} estrellas`}
                    class="inline-submit-loader flex h-10 flex-1 items-center justify-center rounded-lg border border-zinc-800 bg-zinc-900 text-lg text-zinc-600 transition-colors hover:border-accent/50 hover:text-accent"
                  >
                    <span>★</span>
                  </button>
                ))}
              </form>
            ) : (
              <a
                href={`/login?redirect=${encodeURIComponent(`/manga/${slug}`)}`}
                data-no-loader
                class="mt-3 inline-flex w-full items-center justify-center rounded-lg border border-zinc-800 bg-zinc-900 px-3 py-2.5 text-[10px] font-black uppercase tracking-widest text-zinc-300 hover:border-accent/50 hover:text-accent transition-colors"
              >
                Inicia sesión para votar
              </a>
            )}
            {ratingStatus === 'ok' && (
              <p class="mt-3 text-xs text-emerald-300">Voto guardado.</p>
            )}
            {ratingStatus === 'error' && (
              <p class="mt-3 text-xs text-red-300">No pudimos guardar tu voto.</p>
            )}
          </div>
        </aside>

        <div class="min-w-0 pb-2 space-y-10 md:space-y-12">
          <div class="flex flex-wrap items-center gap-2 mb-4">
            {series.sourceName && (
              <span class="text-[10px] font-black uppercase tracking-[0.2em] text-accent">
                {series.sourceName.replace(/^www\./, '')}
              </span>
            )}
            {series.isAdult && (
              <span class="rounded-full bg-accent px-2.5 py-1 text-[10px] font-black uppercase tracking-widest text-zinc-950">
                +18
              </span>
            )}
          </div>

          <h1 class="text-4xl md:text-6xl lg:text-7xl font-black italic tracking-tighter uppercase leading-[0.95] text-white display-shadow">
            {series.title}
          </h1>

          {altTitles.length > 0 && (
            <p class="mt-3 text-sm italic text-zinc-500 line-clamp-1">{altTitles.join(' / ')}</p>
          )}

          {series.description && (
            <p class="mt-6 max-w-4xl text-base md:text-lg leading-8 text-zinc-300 line-clamp-6">
              {series.description}
            </p>
          )}

          {genres.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {genres.slice(0, 12).map((g) => (
                <a
                  href={`/mangas?genre=${encodeURIComponent(g)}`}
                  class="rounded-full bg-zinc-900/80 border border-zinc-800 px-3 py-1.5 text-[10px] font-black uppercase tracking-wider text-zinc-400 hover:border-accent/50 hover:text-accent transition-colors"
                >
                  {formatGenre(g)}
                </a>
              ))}
            </div>
          )}

          <div class="mt-8 flex flex-wrap items-center gap-3">
            {oldestChapter && (
              <a
                href={`/manga/${slug}/${oldestChapter.number}`}
                class="inline-flex items-center gap-2 rounded-xl bg-white px-7 py-3.5 text-sm font-black uppercase tracking-widest text-zinc-950 hover:bg-accent transition-all"
              >
                Leer desde el inicio
              </a>
            )}
            {latestChapter && (
              <a
                href={`/manga/${slug}/${latestChapter.number}`}
                class="inline-flex items-center gap-2 rounded-xl border border-zinc-700 bg-zinc-900/80 px-7 py-3.5 text-sm font-black uppercase tracking-widest text-white hover:border-accent/60 hover:text-accent transition-all"
              >
                Último cap. {latestChapter.number}
              </a>
            )}
          </div>

          {enrichStatus === 'ok' && (
            <div class="mt-4 text-xs px-3 py-2 rounded-md bg-emerald-500/10 text-emerald-300 border border-emerald-500/20">
              Datos actualizados desde MyAnimeList.
            </div>
          )}
          {enrichStatus === 'not_found' && (
            <div class="mt-4 text-xs px-3 py-2 rounded-md bg-accent/10 text-accent-300 border border-accent/30">
              No se encontró una coincidencia para este título.
            </div>
          )}

          {admin && (
            <div class="mt-6 space-y-4 border-t border-zinc-800/60 pt-4">
              <div class="flex flex-wrap items-center gap-2">
                <span class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-600">Admin</span>
                <form method="POST" action={`/api/series/${slug}/banner`}>
                  <input type="hidden" name="redirect" value={`/manga/${slug}`} />
                  <button
                    type="submit"
                    class="rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-zinc-300 hover:border-accent/50 hover:text-accent transition-colors"
                  >
                    Sync banner (AniList)
                  </button>
                </form>
                <form method="POST" action={`/api/series/${slug}/enrich?force=true`}>
                  <input type="hidden" name="redirect" value={`/manga/${slug}`} />
                  <button
                    type="submit"
                    class="rounded-lg border border-accent/40 bg-accent/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-accent hover:bg-accent hover:text-zinc-950 transition-colors"
                  >
                    Re-sync MAL (force)
                  </button>
                </form>
                <form method="POST" action={`/api/admin/series/${slug}/sync`}>
                  <input type="hidden" name="redirect" value={`/manga/${slug}`} />
                  <input type="hidden" name="action" value="sync" />
                  <button
                    type="submit"
                    class="rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-3 py-1.5 text-[10px] font-black uppercase tracking-widest text-emerald-300 hover:bg-emerald-500 hover:text-zinc-950 transition-colors"
                  >
                    Sync now
                  </button>
                </form>
              </div>

              <form method="POST" action={`/api/admin/series/${slug}/monitor`} class="rounded-2xl border border-zinc-800 bg-zinc-950/70 p-4">
                <input type="hidden" name="redirect" value={`/manga/${slug}`} />
                <div class="flex flex-wrap items-center justify-between gap-3">
                  <div>
                    <p class="text-[10px] font-black uppercase tracking-[0.18em] text-zinc-600">Monitoreo local</p>
                    <p class="mt-1 text-xs text-zinc-500">
                      Marca esta serie para que el worker local la revise y suba nuevos caps a R2.
                    </p>
                  </div>
                  <button
                    type="submit"
                    class="rounded-lg bg-white px-4 py-2 text-[10px] font-black uppercase tracking-widest text-zinc-950 hover:bg-accent transition-colors"
                  >
                    Guardar settings
                  </button>
                </div>

                <div class="mt-4 grid gap-4 md:grid-cols-[1fr_1fr_180px]">
                  <label class="flex items-center justify-between rounded-xl border border-zinc-800 bg-zinc-900 px-4 py-3">
                    <span class="text-xs font-bold text-zinc-200">Vigilar actualizaciones</span>
                    <input type="checkbox" name="watch_updates" value="1" checked={series.watchUpdates} class="h-4 w-4 accent-accent" />
                  </label>
                  <label class="flex items-center justify-between rounded-xl border border-zinc-800 bg-zinc-900 px-4 py-3">
                    <span class="text-xs font-bold text-zinc-200">Auto-descargar</span>
                    <input type="checkbox" name="auto_download" value="1" checked={series.autoDownload} class="h-4 w-4 accent-accent" />
                  </label>
                  <label class="rounded-xl border border-zinc-800 bg-zinc-900 px-4 py-3 text-xs font-bold text-zinc-200">
                    Intervalo
                    <select
                      name="check_interval_minutes"
                      class="mt-2 w-full rounded-lg border border-zinc-800 bg-zinc-950 px-3 py-2 text-xs font-bold text-white outline-none focus:border-accent/60"
                    >
                      {[5, 10, 15, 30, 60, 120].map((minutes) => (
                        <option value={minutes} selected={series.checkIntervalMinutes === minutes}>
                          Cada {minutes} min
                        </option>
                      ))}
                    </select>
                  </label>
                </div>

                <div class="mt-3 flex flex-wrap gap-3 text-[10px] font-bold uppercase tracking-[0.16em] text-zinc-500">
                  <span>Watch: {series.watchUpdates ? 'on' : 'off'}</span>
                  <span>Auto: {series.autoDownload ? 'on' : 'off'}</span>
                  <span>Último check: {series.lastCheckedAt ? new Date(series.lastCheckedAt).toLocaleString('es-PE') : '—'}</span>
                  <span>Último sync: {series.lastSyncedAt ? new Date(series.lastSyncedAt).toLocaleString('es-PE') : '—'}</span>
                </div>
              </form>
            </div>
          )}
          {bannerStatus === 'ok' && (
            <div class="mt-3 text-xs px-3 py-2 rounded-md bg-emerald-500/10 text-emerald-300 border border-emerald-500/20">
              Banner sincronizado desde AniList.
            </div>
          )}
          {bannerStatus === 'not_found' && (
            <div class="mt-3 text-xs px-3 py-2 rounded-md bg-accent/10 text-accent-300 border border-accent/30">
              AniList no tiene banner para este título.
            </div>
          )}
          {bannerStatus === 'fetch_failed' && (
            <div class="mt-3 text-xs px-3 py-2 rounded-md bg-red-500/10 text-red-300 border border-red-500/20">
              Error descargando el banner.
            </div>
          )}
          {monitorStatus === 'ok' && (
            <div class="mt-3 text-xs px-3 py-2 rounded-md bg-emerald-500/10 text-emerald-300 border border-emerald-500/20">
              Monitoreo actualizado.
            </div>
          )}
          {monitorStatus === 'queued' && (
            <div class="mt-3 text-xs px-3 py-2 rounded-md bg-emerald-500/10 text-emerald-300 border border-emerald-500/20">
              Trabajo encolado en el motor local.
            </div>
          )}
          {monitorStatus === 'queue_error' && (
            <div class="mt-3 text-xs px-3 py-2 rounded-md bg-red-500/10 text-red-300 border border-red-500/20">
              No pudimos hablar con Redis/BullMQ del motor local.
            </div>
          )}
          <div>
            <div class="flex items-end justify-between gap-4 mb-6">
              <div>
                <h2 class="text-3xl md:text-4xl font-black italic tracking-tighter uppercase text-white">
                  Capítulos
                  <span class="align-middle text-sm font-black not-italic tracking-[0.16em] text-zinc-600">
                    {chapters.length} disponibles
                  </span>
                </h2>
              </div>
            </div>

            <ChapterList
              client:load
              slug={slug}
              chapters={chapters.map((ch) => ({
                number: ch.number,
                title: ch.title,
                language: ch.language,
                pageCount: ch.pageCount,
                previewUrl: ch.previewUrl,
                publishedAt: ch.publishedAt?.toISOString() ?? null,
                downloadedAt: ch.downloadedAt?.toISOString() ?? null,
              }))}
            />
          </div>

          <AdBanner />

          <SeriesComments
            client:load
            slug={slug}
            isLoggedIn={isLoggedIn}
            currentUserEmail={currentUserEmail}
            commentStatus={commentStatus}
          />
        </div>
      </div>
    </section>
  </div>
</Base>
