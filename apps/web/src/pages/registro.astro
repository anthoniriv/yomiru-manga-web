---
import Base from '../layouts/Base.astro';

const redirectTo = Astro.url.searchParams.get('redirect') ?? '/';
const error = Astro.url.searchParams.get('error');
---

<Base title="Crear cuenta">
  <div class="max-w-md mx-auto px-4 pt-16 pb-20">
    <div class="text-center mb-8">
      <p class="text-accent text-[10px] font-black uppercase tracking-[0.28em]">Yomiru</p>
      <h1 class="text-3xl md:text-4xl font-black italic tracking-tighter uppercase leading-none text-white mt-2">
        Crear cuenta
      </h1>
    </div>

    {error && (
      <div class="mb-4 text-xs px-3 py-2 rounded-md bg-red-500/10 text-red-300 border border-red-500/20">
        {error === 'email_taken' && 'Ese email ya está registrado. Intenta iniciar sesión.'}
        {error === 'weak_password' && 'Contraseña muy débil. Usa al menos 6 caracteres.'}
        {error === 'invalid_email' && 'Email inválido.'}
        {error === 'unknown' && 'Error al crear cuenta. Intenta de nuevo.'}
      </div>
    )}

    <form method="POST" action="/api/auth/register" class="space-y-4">
      <input type="hidden" name="redirect" value={redirectTo} />
      <label class="block">
        <span class="block text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500 mb-1">Email</span>
        <input
          type="email"
          name="email"
          required
          autocomplete="email"
          class="w-full rounded-lg bg-zinc-950 border border-zinc-800 px-4 py-3 text-sm text-white focus:outline-none focus:border-accent"
        />
      </label>
      <label class="block">
        <span class="block text-[10px] font-black uppercase tracking-[0.16em] text-zinc-500 mb-1">Contraseña</span>
        <input
          type="password"
          name="password"
          required
          autocomplete="new-password"
          minlength="6"
          class="w-full rounded-lg bg-zinc-950 border border-zinc-800 px-4 py-3 text-sm text-white focus:outline-none focus:border-accent"
        />
        <span class="block text-[10px] text-zinc-600 mt-1">Mínimo 6 caracteres.</span>
      </label>
      <button
        type="submit"
        class="w-full rounded-lg bg-accent px-5 py-3 text-xs font-black uppercase tracking-widest text-zinc-950 hover:bg-white transition-colors shadow-glow-accent"
      >
        Crear cuenta
      </button>
      <p class="text-[10px] text-zinc-600 text-center">
        Te enviaremos un link de verificación por email.
      </p>
    </form>

    <div class="mt-6 text-center text-xs text-zinc-500">
      ¿Ya tienes cuenta?
      <a href={`/login?redirect=${encodeURIComponent(redirectTo)}`} class="text-accent hover:text-white font-black uppercase tracking-widest ml-1">
        Entrar
      </a>
    </div>
  </div>
</Base>
